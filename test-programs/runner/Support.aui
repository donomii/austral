import Standard.OS.FileSystem (
    DirectoryList
);
import Standard.OS.Process (
    CommandResult
);
import Standard.String (
    String
);

module TestPrograms.Runner.Support is
    function emptyString(): String;

    function argumentToString(index: Index): String;

    function argumentEquals(index: Index, value: Span[Nat8, Static]): Bool;

    function argumentIsFlag(index: Index): Bool;

    function destroyOptionalString(value: Option[String]): Unit;

    generic [R: Region]
    function printString(value: &[String, R]): Unit;

    generic [R: Region, S: Region]
    function printResult(suite: &[String, R], test: &[String, S], passed: Bool): Unit;

    generic [R: Region, S: Region]
    function tempCPath(suite: &[String, R], test: &[String, S]): String;

    generic [R: Region, S: Region]
    function tempBinPath(suite: &[String, R], test: &[String, S]): String;

    generic [R: Region]
    function readFileTrim(path: &[String, R]): Option[String];

    generic [R: Region, S: Region]
    function writeFile(path: &[String, R], contents: &[String, S]): Bool;

    generic [R: Region, S: Region]
    function defaultCompileCommand(testDir: &[String, R], cPath: &[String, S]): String;

    generic [R: Region, S: Region, T: Region]
    function cliCompileCommand(cli: &[String, R], testDir: &[String, S], cPath: &[String, T]): String;

    generic [R: Region, S: Region]
    function cCompilerCommand(cPath: &[String, R], binPath: &[String, S]): String;

    generic [R: Region]
    function binaryCommand(binPath: &[String, R]): String;

    generic [R: Region]
    function runCommand(command: &[String, R], stdin: Option[String]): CommandResult;

    generic [R: Region]
    function commandExitCode(result: &[CommandResult, R]): Int32;

    generic [R: Region]
    function commandStdout(result: &[CommandResult, R]): String;

    generic [R: Region]
    function commandStderr(result: &[CommandResult, R]): String;

    function commandDestroy(result: CommandResult): Unit;

    function resetFailures(): Unit;
end module.
