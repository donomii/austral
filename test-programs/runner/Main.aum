import Standard.OS.FileSystem (
    DirectoryList,
    listDirectories,
    directoryCount,
    directoryName,
    destroyDirectoryList,
    pathJoin,
    pathJoinLiteral,
    readFile
);
import Standard.OS.Process (
    CommandResult
);
import Standard.String (
    String,
    fromLiteral,
    destroyString,
    isEmpty,
    equals,
    contains,
    strip,
    trimLines
);
import TestPrograms.Runner.Support (
    emptyString,
    argumentEquals,
    argumentIsFlag,
    argumentToString,
    destroyOptionalString,
    printResult,
    tempCPath,
    tempBinPath,
    readFileTrim,
    writeFile,
    defaultCompileCommand,
    cliCompileCommand,
    cCompilerCommand,
    binaryCommand,
    runCommand,
    commandExitCode,
    commandStdout,
    commandStderr,
    commandDestroy,
    resetFailures
);

module body TestPrograms.Runner.Main is
    function assertTest(condition: Bool, message: Span[Nat8, Static]): Unit is
        if not condition then
            abort(message);
        end if;
        return nil;
    end;

    function hasFlag(flag: Span[Nat8, Static]): Bool is
        if argumentCount() > 1 then
            for i from 1 to argumentCount() - 1 do
                if argumentEquals(i, flag) then
                    return true;
                end if;
            end for;
        end if;
        return false;
    end;

    function positionalArgument(target: Index): String is
        var seen: Index := 0;
        if argumentCount() > 1 then
            for i from 1 to argumentCount() - 1 do
                if not argumentIsFlag(i) then
                    if seen = target then
                        return argumentToString(i);
                    else
                        seen := seen + 1;
                    end if;
                end if;
            end for;
        end if;
        return emptyString();
    end;

    generic [R: Region, S: Region]
    function matchesPattern(value: &[String, R], pattern: &[String, S]): Bool is
        if isEmpty(pattern) then
            return true;
        else
            return contains(value, pattern);
        end if;
    end;

    generic [R: Region]
    function readExpectedFile(path: &[String, R]): Option[String] is
        case readFileTrim(path) of
            when Some(value as contents: String) do
                if isEmpty(&contents) then
                    abort("expected test control file exists but is empty");
                end if;
                return Some(value => contents);
            when None do
                return None();
        end case;
    end;

    generic [R: Region, S: Region]
    function compileCommandFor(testDir: &[String, R], cPath: &[String, S], cli: Option[String]): String is
        case cli of
            when Some(value as cliText: String) do
                let command: String := cliCompileCommand(&cliText, testDir, cPath);
                destroyString(cliText);
                return command;
            when None do
                return defaultCompileCommand(testDir, cPath);
        end case;
    end;

    generic [A: Region, B: Region]
    function runSuccessTest(
        suite: &[String, A],
        test: &[String, B],
        testDir: String,
        cPath: String,
        binPath: String,
        cli: Option[String],
        programStdin: Option[String],
        expectedOutput: Option[String]
    ): Bool is
        let compileCommand: String := compileCommandFor(&testDir, &cPath, cli);
        let compileResult: CommandResult := runCommand(&compileCommand, None() : Option[String]);
        assertTest(commandExitCode(&compileResult) = 0, "Austral compilation failed, but was expected to succeed.");
        commandDestroy(compileResult);

        let ccCommand: String := cCompilerCommand(&cPath, &binPath);
        let ccResult: CommandResult := runCommand(&ccCommand, None() : Option[String]);
        assertTest(commandExitCode(&ccResult) = 0, "C compilation failed, but was expected to succeed.");
        commandDestroy(ccResult);

        let runBinCommand: String := binaryCommand(&binPath);
        let runResult: CommandResult := runCommand(&runBinCommand, programStdin);
        assertTest(commandExitCode(&runResult) = 0, "Program terminated abnormally.");

        let rawStdout: String := commandStdout(&runResult);
        let stdout: String := strip(&rawStdout);
        destroyString(rawStdout);
        case expectedOutput of
            when Some(value as expected: String) do
                assertTest(equals(&stdout, &expected), "Program produced the wrong stdout.");
                destroyString(expected);
            when None do
                assertTest(isEmpty(&stdout), "Program produced stdout, which we did not expect.");
        end case;

        destroyString(stdout);
        commandDestroy(runResult);
        destroyString(runBinCommand);
        destroyString(ccCommand);
        destroyString(compileCommand);
        destroyString(testDir);
        destroyString(cPath);
        destroyString(binPath);
        printResult(suite, test, true);
        return true;
    end;

    generic [A: Region, B: Region]
    function runCompilerFailureTest(
        suite: &[String, A],
        test: &[String, B],
        testDir: String,
        cPath: String,
        binPath: String,
        cli: Option[String],
        expectedErrorPath: String,
        expectedError: String,
        replaceStderr: Bool
    ): Bool is
        let compileCommand: String := compileCommandFor(&testDir, &cPath, cli);
        let compileResult: CommandResult := runCommand(&compileCommand, None() : Option[String]);
        assertTest(commandExitCode(&compileResult) /= 0, "Austral compiler succeeded, but was expected to fail.");

        let rawStderr: String := commandStderr(&compileResult);
        let actualStderr: String := trimLines(&rawStderr);
        destroyString(rawStderr);
        if replaceStderr then
            assertTest(writeFile(&expectedErrorPath, &actualStderr), "failed to replace expected stderr");
        else
            let expectedTrimmed: String := trimLines(&expectedError);
            assertTest(equals(&actualStderr, &expectedTrimmed), "Austral compiler output does not match expected stderr.");
            destroyString(expectedTrimmed);
        end if;

        destroyString(actualStderr);
        destroyString(expectedError);
        destroyString(expectedErrorPath);
        commandDestroy(compileResult);
        destroyString(compileCommand);
        destroyString(testDir);
        destroyString(cPath);
        destroyString(binPath);
        printResult(suite, test, true);
        return true;
    end;

    generic [A: Region, B: Region]
    function runProgramFailureTest(
        suite: &[String, A],
        test: &[String, B],
        testDir: String,
        cPath: String,
        binPath: String,
        cli: Option[String],
        programStdin: Option[String],
        expectedProgramStderr: String
    ): Bool is
        let compileCommand: String := compileCommandFor(&testDir, &cPath, cli);
        let compileResult: CommandResult := runCommand(&compileCommand, None() : Option[String]);
        assertTest(commandExitCode(&compileResult) = 0, "Austral compilation failed, but was expected to succeed.");
        commandDestroy(compileResult);

        let ccCommand: String := cCompilerCommand(&cPath, &binPath);
        let ccResult: CommandResult := runCommand(&ccCommand, None() : Option[String]);
        assertTest(commandExitCode(&ccResult) = 0, "C compilation failed, but was expected to succeed.");
        commandDestroy(ccResult);

        let runBinCommand: String := binaryCommand(&binPath);
        let runResult: CommandResult := runCommand(&runBinCommand, programStdin);
        assertTest(commandExitCode(&runResult) /= 0, "Program terminated successfully, but we expected a failure.");

        let rawStderr: String := commandStderr(&runResult);
        let stderr: String := strip(&rawStderr);
        destroyString(rawStderr);
        assertTest(equals(&stderr, &expectedProgramStderr), "Program produced stderr, but it was not what we expected.");

        destroyString(stderr);
        destroyString(expectedProgramStderr);
        commandDestroy(runResult);
        destroyString(runBinCommand);
        destroyString(ccCommand);
        destroyString(compileCommand);
        destroyString(testDir);
        destroyString(cPath);
        destroyString(binPath);
        printResult(suite, test, true);
        return true;
    end;

    generic [A: Region, B: Region, C: Region, D: Region, E: Region]
    function runTest(
        suite: &[String, A],
        test: &[String, B],
        suiteDir: &[String, C],
        suitePattern: &[String, D],
        testPattern: &[String, E],
        replaceStderr: Bool
    ): Bool is
        if not matchesPattern(suite, suitePattern) then
            return true;
        end if;
        if not matchesPattern(test, testPattern) then
            return true;
        end if;

        let testDir: String := pathJoin(suiteDir, test);
        let cPath: String := tempCPath(suite, test);
        let binPath: String := tempBinPath(suite, test);

        let expectedErrorPath: String := pathJoinLiteral(&testDir, "austral-stderr.txt");
        let expectedOutputPath: String := pathJoinLiteral(&testDir, "program-stdout.txt");
        let programStderrPath: String := pathJoinLiteral(&testDir, "program-stderr.txt");
        let programStdinPath: String := pathJoinLiteral(&testDir, "program-stdin.txt");
        let cliPath: String := pathJoinLiteral(&testDir, "cli.txt");

        let expectedError: Option[String] := readExpectedFile(&expectedErrorPath);
        let expectedOutput: Option[String] := readExpectedFile(&expectedOutputPath);
        let programStderr: Option[String] := readExpectedFile(&programStderrPath);
        let programStdin: Option[String] := readFile(&programStdinPath);
        let cli: Option[String] := readExpectedFile(&cliPath);

        destroyString(expectedOutputPath);
        destroyString(programStderrPath);
        destroyString(programStdinPath);
        destroyString(cliPath);

        case expectedError of
            when Some(value as expectedErrorText: String) do
                destroyOptionalString(programStderr);
                destroyOptionalString(programStdin);
                case expectedOutput of
                    when Some(value as unexpectedOutput: String) do
                        destroyString(unexpectedOutput);
                        destroyString(expectedErrorText);
                        destroyString(expectedErrorPath);
                        destroyOptionalString(cli);
                        destroyString(testDir);
                        destroyString(cPath);
                        destroyString(binPath);
                        abort("test cannot have both austral-stderr.txt and program-stdout.txt");
                    when None do
                        return runCompilerFailureTest(
                            suite,
                            test,
                            testDir,
                            cPath,
                            binPath,
                            cli,
                            expectedErrorPath,
                            expectedErrorText,
                            replaceStderr
                        );
                end case;
            when None do
                destroyString(expectedErrorPath);
                case expectedOutput of
                    when Some(value as expectedOutputText: String) do
                        destroyOptionalString(programStderr);
                        return runSuccessTest(
                            suite,
                            test,
                            testDir,
                            cPath,
                            binPath,
                            cli,
                            programStdin,
                            Some(value => expectedOutputText)
                        );
                    when None do
                        case programStderr of
                            when Some(value as programStderrText: String) do
                                return runProgramFailureTest(
                                    suite,
                                    test,
                                    testDir,
                                    cPath,
                                    binPath,
                                    cli,
                                    programStdin,
                                    programStderrText
                                );
                            when None do
                                return runSuccessTest(
                                    suite,
                                    test,
                                    testDir,
                                    cPath,
                                    binPath,
                                    cli,
                                    programStdin,
                                    None() : Option[String]
                                );
                        end case;
                end case;
        end case;
    end;

    generic [A: Region, B: Region]
    function runAll(replaceStderr: Bool, suitePattern: &[String, A], testPattern: &[String, B]): Bool is
        printLn("Collecting...");
        let root: String := fromLiteral("test-programs");
        let suitesDir: String := pathJoinLiteral(&root, "suites");
        let suites: DirectoryList := listDirectories(&suitesDir);
        var allPassed: Bool := true;

        printLn("Running...");
        if directoryCount(&suites) > 0 then
            for suiteIndex from 0 to directoryCount(&suites) - 1 do
                let suite: String := directoryName(&suites, suiteIndex);
                let suiteDir: String := pathJoin(&suitesDir, &suite);
                let tests: DirectoryList := listDirectories(&suiteDir);
                if directoryCount(&tests) > 0 then
                    for testIndex from 0 to directoryCount(&tests) - 1 do
                        let test: String := directoryName(&tests, testIndex);
                        if not runTest(&suite, &test, &suiteDir, suitePattern, testPattern, replaceStderr) then
                            allPassed := false;
                        end if;
                        destroyString(test);
                    end for;
                end if;
                destroyDirectoryList(tests);
                destroyString(suiteDir);
                destroyString(suite);
            end for;
        end if;

        destroyDirectoryList(suites);
        destroyString(suitesDir);
        destroyString(root);
        return allPassed;
    end;

    function main(root: RootCapability): ExitCode is
        resetFailures();
        let replaceStderr: Bool := hasFlag("--replace-stderr");
        let suitePattern: String := positionalArgument(0);
        let testPattern: String := positionalArgument(1);
        let ok: Bool := runAll(replaceStderr, &suitePattern, &testPattern);
        destroyString(suitePattern);
        destroyString(testPattern);
        surrenderRoot(root);
        if ok then
            printLn("");
            printLn("All tests passed");
            return ExitSuccess();
        else
            printLn("");
            printLn("Some tests failed");
            return ExitFailure();
        end if;
    end;
end module body.
