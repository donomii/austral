module body Test is
    record Foo: Linear is end;
    record Bar[R: Region]: Linear is end;

    generic [Reg: Region]
    function makeBar(f: &[Foo, Reg]): Bar[Reg] is
        let b: Bar[Reg] := Bar();
        return b;
    end;

    function main(): ExitCode is
        let f: Foo := Foo();
        borrow ref: &[Foo, Reg] := &f do
            let b: Bar[Reg] := makeBar(ref);
            let {} := b;
        end borrow;
        let {} := f;
        return ExitSuccess();
    end;
end module body.

