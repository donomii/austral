pragma Unsafe_Module;

module body Test is
    function Put_Character(character: Nat8): Int32 is
        return @embed(Int32, "au_os_fputc((int)$1, au_stdout())", character);
    end;

    function main(): ExitCode is
        let c: Nat8 := @embed(Nat8, "$1 + $2", 90, 7);
        Put_Character(c);
        return ExitSuccess();
    end;
end module body.
