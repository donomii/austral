pragma Unsafe_Module;

module body Test is
    function Put_Character(character: Nat8): Int32 is
        return @embed(Int32, "au_os_fputc((int)$1, au_stdout())", character);
    end;

    function Put_String(str: Span[Nat8, Static]): Int32 is
        return @embed(Int32, "(au_printf(\"%.*s\n\", (int)($1).size, (char*)($1).data), 0)", str);
    end;

    function main(): ExitCode is
        let X: Span[Nat8, Static] := "Hello, world!";
        let len: Index := spanLength(X);
        if len = 13 then
            Put_Character(X[0]);
            Put_String(X);
        end if;
        Put_String(
            """A"""
        );
        Put_String(
            """A
            """
        );
        Put_String(
            """
                A"""
        );
        Put_String(
            """
                A
            """
        );
        Put_String(
            """
                A
                    B
            """
        );
        Put_String(
            """
                A
                    B
                C
            """
        );
        return ExitSuccess();
    end;
end module body.
