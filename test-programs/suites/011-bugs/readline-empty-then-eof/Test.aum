import Standard.IO (
    TerminalCapability,
    acquireTerminal,
    releaseTerminal
);
import Standard.IO.Terminal (
    StandardInput,
    acquireInput,
    releaseInput,
    readLine
);
import Standard.String (
    String,
    destroyString,
    length
);

module body Test is
    function main(root: RootCapability): ExitCode is
        var mutRoot: RootCapability := root;
        var terminal: TerminalCapability := acquireTerminal(&!mutRoot);
        var input: StandardInput := acquireInput(&!terminal);

        case readLine(&!input) of
            when Some(value as line: String) do
                if length(&line) = 0 then
                    printLn("EMPTY");
                else
                    printLn("BAD");
                end if;
                destroyString(line);
            when None do
                printLn("BAD");
        end case;

        case readLine(&!input) of
            when Some(value as line: String) do
                destroyString(line);
                printLn("BAD");
            when None do
                printLn("EOF");
        end case;

        releaseInput(input);
        releaseTerminal(terminal);
        surrenderRoot(mutRoot);
        return ExitSuccess();
    end;
end module body.
