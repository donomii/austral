"""
Environment variable access.
"""
import Standard.String (
    String
);

module Standard.OS.Environment is
    generic [R: Region]
    function get(name: &[String, R]): Option[String];

    function getLiteral(name: Span[Nat8, Static]): Option[String];
end module.
